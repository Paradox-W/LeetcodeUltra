{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm",
            "dependsOrder": "sequence",
            "dependsOn": [
                "prepare_debug_profile",
                "npm_rm",
                "npm_do"
            ]
        },
        {
            "label": "prepare_debug_profile",
            "type": "shell",
            "command": "node",
            "args": [
                "scripts/prepare-debug-profile.js"
            ],
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        },
        {
            "label": "window_npm",
            "dependsOrder": "sequence",
            "dependsOn": [
                "window_npm_rm",
                "window_npm_do"
            ]
        },
        {
            "label": "window_npm_rm",
            "type": "shell",
            "command": "Remove-item",
            "args": [
                "out",
                "-recurse"
            ],
            // "isBackground": true,
        },
        {
            "label": "window_npm_do",
            "type": "shell",
            "command": "npm",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "args": [
                "run",
                "compile",
                "--loglevel",
                "silent"
            ],
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$tsc"
        },
        {
            "label": "npm_rm",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "out"
            ],
            "windows": {
                "command": "Remove-item",
                "args": [
                    "out",
                    "-recurse"
                ],
            }
            // "isBackground": true,
        },
        {
            "label": "npm_do",
            "type": "shell",
            "command": "npm",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "args": [
                "run",
                "compile",
                "--loglevel",
                "silent"
            ],
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$tsc"
        },
        {
            "type": "npm",
            "script": "lint",
            // "problemMatcher": {
            //     "base": "$tslint5",
            //     "fileLocation": "absolute"
            // }
        }
    ]
}
